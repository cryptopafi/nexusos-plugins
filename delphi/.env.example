# DELPHI PRO — Required API Keys
# Copy to ~/.nexus/.env and fill in your keys

OPENROUTER_API_KEY=sk-or-v1-your-key-here
GROQ_API_KEY=gsk_your-groq-key-here
GEMINI_API_KEY=your-gemini-key-here
APIFY_API_KEY=apify_api_your-key-here
NOTION_TOKEN=ntn_your-notion-token-here

BRAVE_SEARCH_API_KEY=your-brave-key-here
NAMESILO_API_KEY=your-namesilo-key-here

# Optional
GUARDIAN_API_KEY=test  # Guardian free tier uses 'test' as key
GNEWS_API_KEY=your-gnews-key-here
TAVILY_API_KEY=tvly-your-tavily-key-here
EXA_API_KEY=your-exa-key-here

BLUESKY_HANDLE=your.handle.bsky.social
BLUESKY_APP_PASSWORD=your-app-password-here
VPS_HOST=your-vps-hostname
MAX_COST_PER_RUN=8.0
