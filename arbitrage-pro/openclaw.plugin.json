{
  "name": "arbitrage-pro",
  "version": "1.0.0",
  "description": "Arbitrage Pro — EU auction-to-marketplace deal hunter",
  "author": "NexusOS",
  "license": "MIT",
  "engines": { "openclaw": ">=0.9.0" },
  "configSchema": {
    "type": "object",
    "properties": {
      "openrouter_api_key": { "type": "string", "description": "OpenRouter API key for Perplexity Sonar" },
      "brave_api_key": { "type": "string", "description": "Brave Search API key" },
      "exa_api_key": { "type": "string", "description": "Exa search API key" },
      "apify_api_key": { "type": "string", "description": "Apify API key for auction scraping" },
      "telegram_bot_token": { "type": "string", "description": "Telegram bot token for deal alerts" },
      "telegram_chat_id": { "type": "string", "description": "Telegram chat ID for alerts" },
      "vps_host": { "type": "string", "description": "VPS hostname for HTML report deployment" },
      "max_cost_per_run": { "type": "number", "default": 2.0, "description": "Max USD per hunt run" }
    },
    "required": ["exa_api_key", "apify_api_key"]
  },
  "capabilities": { "skills": true, "commands": true, "hooks": true, "tools": false, "services": false },
  "bundle": { "type": "claude", "path": "." }
}
