# Arbitrage Pro — Required Environment Variables
# Copy to ~/.nexus/.env or set in macOS Keychain

# ─── Wave 1 (MVP) ───────────────────────────────────────────
# Apify API key for auction scrapers (Troostwijk, Catawiki, OLX)
APIFY_API_KEY=your_apify_key_here

# eBay Browse API credentials (free registration at developer.ebay.com)
# EBAY_APP_ID=your_ebay_app_id_here

# ─── Wave 2 (Market Oracle) ─────────────────────────────────
# Fuel prices API (fuel-prices.eu, $17/month)
# FUEL_PRICES_API_KEY=your_fuel_prices_key_here

# Trans.eu freight exchange API (requires sales contact)
# TRANS_EU_API_KEY=your_trans_eu_key_here

# ─── Wave 3 (Scale) ─────────────────────────────────────────
# TBAuctions ATLAS API (requires developer account via sales)
# TBAUCTIONS_API_KEY=your_atlas_key_here
# TBAUCTIONS_SUBSCRIPTION_KEY=your_subscription_key_here

# TIMOCOM API
# TIMOCOM_API_KEY=your_timocom_key_here

# ─── Already configured in NexusOS ──────────────────────────
# These should already exist in ~/.nexus/.env:
# BRAVE_SEARCH_API_KEY (for fallback searches)
# NOTION_TOKEN (for Wave 3 Notion Deal Tracker)
